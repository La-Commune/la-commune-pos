# ══════════════════════════════════════════════
# La Commune POS — Environment Variables
# ══════════════════════════════════════════════
# Copia este archivo como .env.development o .env.production
# y llena los valores correspondientes.
#
# Scripts:
#   npm run dev          → usa .env.development
#   npm run dev:prod     → usa .env.production
#   npm run build        → usa .env.production (default para deploy)
#   npm run build:dev    → usa .env.development
# ══════════════════════════════════════════════

# ── Supabase — obtén estos valores en supabase.com > Project Settings > API ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Negocio — ID del registro en tabla negocios ──
NEXT_PUBLIC_NEGOCIO_ID=

# ── Auth por PIN — HMAC secret para generar passwords determinísticos ──
PIN_PASSWORD_SECRET=

# ── Push Notifications — VAPID keys (generar con: npx web-push generate-vapid-keys) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
